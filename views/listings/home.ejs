<% layout("layouts/boilerplate") %>
<div class="hero-section text-center text-white d-flex align-items-center justify-content-center">
  <div>
    <h1 class="display-3 fw-bold">Welcome to WanderLust 🌍</h1>
    <p class="lead mt-3">Find your dream stay across the world — cottages, villas, penthouses & more!</p>
    <a href="/listings" class="btn btn-lg btn-light mt-4">Explore Listings</a>
  </div>
</div>

<div class="container mt-5">
  <div class="row text-center">
    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title">🏡 Unique Stays</h5>
          <p class="card-text">Treehouses, castles, cottages — explore one-of-a-kind places.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4 mt-3 mt-md-0">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title">🌐 Global Destinations</h5>
          <p class="card-text">Travel across continents and discover listings worldwide.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4 mt-3 mt-md-0">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title">✨ Easy Management</h5>
          <p class="card-text">Add, edit, or delete listings with just a few clicks.</p>
        </div>
      </div>
    </div>
  </div>
</div>